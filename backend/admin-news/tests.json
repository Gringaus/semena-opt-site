{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Получить список новостей",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "POST без токена",
      "method": "POST",
      "path": "/",
      "body": {"title": "test"},
      "expectedStatus": 401
    },
    {
      "name": "Получить архив",
      "method": "GET",
      "path": "/?kind=archive",
      "expectedStatus": 200
    },
    {
      "name": "Новость по slug — не найдена",
      "method": "GET",
      "path": "/?slug=nonexistent-news-slug-xyz-12345",
      "expectedStatus": 404
    }
  ]
}